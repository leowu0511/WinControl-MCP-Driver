# WCMD 環境變數範本
# ====================================================
# 複製此檔為 .env，然後填入你的真實值
# Windows: copy .env.example .env
# macOS/Linux: cp .env.example .env
#
# ⚠️ 永遠不要把 .env commit 到版控 (已加進 .gitignore)
# ====================================================

# === Vision Model 設定 (必要) ===
# 從供應商取得 API Key
WCMD_VISION_API_KEY=sk-your-api-key-here

# BASE_URL 與模型依供應商而定：
# OpenCode Go (推薦)
WCMD_VISION_BASE_URL=https://opencode.ai/zen/go
WCMD_VISION_MODEL=qwen3.7-plus

# OpenCode Zen
# WCMD_VISION_BASE_URL=https://opencode.ai/zen/v1
# WCMD_VISION_MODEL=qwen3.6-plus

# 阿里雲 DashScope
# WCMD_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# WCMD_VISION_MODEL=qwen-vl-plus

# OpenAI
# WCMD_VISION_BASE_URL=https://api.openai.com/v1
# WCMD_VISION_MODEL=gpt-4o

# === 進階設定 (選用) ===
# 資料目錄 (預設 ~/.wcmd/)
# WCMD_DATA_DIR=C:\\wcmd-data

# 開啟 debug log (MCP server log 走 stderr)
# WCMD_DEBUG=1
